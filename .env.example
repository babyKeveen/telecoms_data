# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Anthropic API key — required for natural language trip search
ANTHROPIC_API_KEY=your_key_here

# Absolute path to your local data directory.
# This folder should contain: stage/, sim/raw/, vector_db/
#
# Windows example:
# DATA_PATH=C:\S3Data
#
# Mac / Linux example:
# DATA_PATH=/Users/yourname/S3Data
DATA_PATH=C:\S3Data
